release/mr_res.o: ../../mr.rc
	windres -i ..\..\mr.rc -o release\mr_res.o --include-dir=./../.. $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release ..\..\HafenResTool.pro -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug"

